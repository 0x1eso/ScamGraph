{
  "manifest_version": 3,
  "name": "ScamGraph 방패",
  "version": "0.1.0",
  "description": "방문 사이트의 사기·피싱 위험을 실시간 검사",
  "permissions": ["activeTab", "tabs", "storage"],
  "host_permissions": ["http://localhost:8080/*"],
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_popup": "popup.html",
    "default_title": "ScamGraph"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ]
}
